# Storefront (Vite) environment. Copy to `.env` and fill real values.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# API base URL. Dev: the api-server origin (e.g. http://localhost:3001).
# Leave empty to call the API same-origin under /api.
VITE_API_URL=

# Supabase project — used ONLY for auth (session + JWT sent to the API as a bearer).
# The anon key is public and safe to ship in the browser; it grants nothing without RLS,
# and this app never queries the DB directly (all data goes through api-server).
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
